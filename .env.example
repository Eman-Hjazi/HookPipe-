# ==============================================================================
# HookPipe Environment Configuration Template
# This file defines the required environment variables for the system.
# Copy this file to '.env' and modify it for your local setup. 
# ==============================================================================
# --- Project General Settings ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL Database Configuration ---
# These credentials will be used by the 'db' service in Docker Compose. [2, 3]
POSTGRES_USER=hookpipe_admin
POSTGRES_PASSWORD=hookpipe_pass
POSTGRES_DB=hookpipe_database

# --- Application Database Connection ---
# Use the service name 'db' as the host for Docker internal communication. [1, 2]
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://hookpipe_admin:hookpipe_pass@db:5432/hookpipe_database

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
