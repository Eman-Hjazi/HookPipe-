{
  "name": "hookpipe",
  "version": "1.0.0",
  "description": "Webhook-Driven Task Processing Pipeline",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "dev:api": "tsx --watch src/api/index.ts",
    "dev:worker": "tsx --watch src/worker/index.ts",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "format:write": "prettier --write \"src/**/*.{js,ts,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,json,css,md}\"",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^5.8.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.0"
  }
}
